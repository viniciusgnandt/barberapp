PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/barberapp
JWT_SECRET=troque_por_uma_string_secreta_longa

# OCI Object Storage (S3-compatible)
# Deixe em branco para usar armazenamento local em desenvolvimento
OCI_REGION=us-phoenix-1
OCI_NAMESPACE=
OCI_BUCKET_NAME=
OCI_ACCESS_KEY_ID=
OCI_SECRET_ACCESS_KEY=

# Upload settings
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
